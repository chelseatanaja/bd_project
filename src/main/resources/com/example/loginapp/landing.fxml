<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.loginapp.LandingController"
            prefWidth="1000"
            prefHeight="650"
            style="-fx-background-color: linear-gradient(to bottom right, #F4F7FF, #EEF3FF);">

    <center>
        <VBox alignment="CENTER" spacing="28">

            <Label text="▣"
                   textFill="#2563EB"
                   style="-fx-font-size:64;"/>

            <Label text="LMS Database Management"
                   textFill="#0F172A">
                <font>
                    <Font name="System Bold" size="42"/>
                </font>
            </Label>

            <Label text="Manage classes, assignments, users, and academic data with PostgreSQL integration."
                   textFill="#64748B"
                   wrapText="true"
                   maxWidth="600"
                   alignment="CENTER">
                <font>
                    <Font size="17"/>
                </font>
            </Label>

            <HBox alignment="CENTER" spacing="16">
                <Button fx:id="btnLogin"
                        text="LOGIN"
                        prefWidth="170"
                        prefHeight="52"
                        style="-fx-background-color: linear-gradient(to right, #4F46E5, #2563EB);
                               -fx-text-fill:white;
                               -fx-font-weight:bold;
                               -fx-font-size:15;
                               -fx-background-radius:15;"/>

                <Button fx:id="btnSignUp"
                        text="SIGN UP"
                        prefWidth="170"
                        prefHeight="52"
                        style="-fx-background-color:white;
                               -fx-text-fill:#2563EB;
                               -fx-font-weight:bold;
                               -fx-font-size:15;
                               -fx-border-color:#2563EB;
                               -fx-border-radius:15;
                               -fx-background-radius:15;"/>
            </HBox>

        </VBox>
    </center>

</BorderPane>