<!-- dashboard.fxml HAPUS NANTI -->
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/8.0.171"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.bd1_2.DashboardController"
            prefWidth="1280" prefHeight="760"
            style="-fx-background-color: linear-gradient(to bottom right, #EEF2FF, #F8FAFC);">

    <left>
        <VBox prefWidth="255" spacing="18"
              style="-fx-background-color: linear-gradient(to bottom, #0F172A, #1E1B4B);">
            <padding>
                <Insets top="30" right="20" bottom="30" left="20"/>
            </padding>

            <Label text="LMS Admin" textFill="WHITE">
                <font><Font name="System Bold" size="26"/></font>
            </Label>

            <Label text="Database Management" textFill="#A5B4FC"/>

            <Separator opacity="0.18"/>

            <Button text="Dashboard" maxWidth="Infinity"
                    style="-fx-background-color:#6366F1; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:14; -fx-padding:13;"/>

            <Button text="Manage Kelas" maxWidth="Infinity"
                    style="-fx-background-color:transparent; -fx-text-fill:#CBD5E1; -fx-padding:13;"/>

            <Button text="Manage Assignment" maxWidth="Infinity"
                    style="-fx-background-color:transparent; -fx-text-fill:#CBD5E1; -fx-padding:13;"/>

            <Button text="Reports" maxWidth="Infinity"
                    style="-fx-background-color:transparent; -fx-text-fill:#CBD5E1; -fx-padding:13;"/>

            <Region VBox.vgrow="ALWAYS"/>

            <VBox spacing="8"
                  style="-fx-background-color:rgba(255,255,255,0.08); -fx-background-radius:16; -fx-padding:16;">
                <Label text="Database Status" textFill="#CBD5E1"/>
                <Label text="● PostgreSQL Connected" textFill="#4ADE80"/>
            </VBox>
        </VBox>
    </left>

    <center>
        <VBox spacing="24">
            <padding>
                <Insets top="30" right="34" bottom="30" left="34"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="16">
                <VBox spacing="4">
                    <Label text="Academic Dashboard" textFill="#0F172A">
                        <font><Font name="System Bold" size="32"/></font>
                    </Label>
                    <Label text="Manage master data, transaction data, and business reports"
                           textFill="#64748B"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <TextField fx:id="txtSearch"
                           promptText="Search anything..."
                           prefWidth="280"
                           prefHeight="42"
                           style="-fx-background-color:white; -fx-background-radius:14; -fx-border-color:#E2E8F0; -fx-border-radius:14; -fx-padding:0 14;"/>

                <Button text="Refresh"
                        prefHeight="42"
                        style="-fx-background-color:#0F172A; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:14; -fx-padding:0 22;"/>
            </HBox>

            <HBox spacing="18">
                <VBox spacing="10" prefWidth="240"
                      style="-fx-background-color:white; -fx-background-radius:22; -fx-padding:22;">
                    <Label text="Total Kelas" textFill="#64748B"/>
                    <Label fx:id="lblTotalKelas" text="24" textFill="#0F172A">
                        <font><Font name="System Bold" size="34"/></font>
                    </Label>
                    <Label text="+12% this semester" textFill="#22C55E"/>
                </VBox>

                <VBox spacing="10" prefWidth="240"
                      style="-fx-background-color:white; -fx-background-radius:22; -fx-padding:22;">
                    <Label text="Assignments" textFill="#64748B"/>
                    <Label fx:id="lblTotalAssignment" text="128" textFill="#0F172A">
                        <font><Font name="System Bold" size="34"/></font>
                    </Label>
                    <Label text="18 active deadlines" textFill="#F97316"/>
                </VBox>

                <VBox spacing="10" prefWidth="240"
                      style="-fx-background-color:white; -fx-background-radius:22; -fx-padding:22;">
                    <Label text="Submissions" textFill="#64748B"/>
                    <Label fx:id="lblTotalSubmission" text="842" textFill="#0F172A">
                        <font><Font name="System Bold" size="34"/></font>
                    </Label>
                    <Label text="Updated recently" textFill="#6366F1"/>
                </VBox>
            </HBox>

            <HBox spacing="24" VBox.vgrow="ALWAYS">

                <VBox spacing="16" prefWidth="440"
                      style="-fx-background-color:white; -fx-background-radius:24; -fx-padding:24;">
                    <Label text="Manage Kelas" textFill="#0F172A">
                        <font><Font name="System Bold" size="22"/></font>
                    </Label>

                    <TextField fx:id="txtKelasId" promptText="Kelas ID"/>
                    <TextField fx:id="txtKelasNama" promptText="Nama Kelas"/>
                    <TextField fx:id="txtKelasKapasitas" promptText="Kapasitas"/>
                    <TextField fx:id="txtKelasSemester" promptText="Semester"/>

                    <HBox spacing="10">
                        <Button fx:id="btnAddKelas" text="Add" prefWidth="92" style="-fx-background-color:#6366F1; -fx-text-fill:white; -fx-background-radius:12;"/>
                        <Button fx:id="btnEditKelas" text="Edit" prefWidth="92" style="-fx-background-color:#F59E0B; -fx-text-fill:white; -fx-background-radius:12;"/>
                        <Button fx:id="btnDeleteKelas" text="Delete" prefWidth="92" style="-fx-background-color:#EF4444; -fx-text-fill:white; -fx-background-radius:12;"/>
                        <Button fx:id="btnClearKelas" text="Clear" prefWidth="92" style="-fx-background-color:#64748B; -fx-text-fill:white; -fx-background-radius:12;"/>
                    </HBox>

                    <TextField fx:id="txtSearchKelas" promptText="Search kelas..."/>

                    <TableView fx:id="tblKelas" VBox.vgrow="ALWAYS"
                               style="-fx-background-radius:16; -fx-border-radius:16;">
                        <columns>
                            <TableColumn fx:id="colKelasId" text="ID" prefWidth="70"/>
                            <TableColumn fx:id="colKelasNama" text="Nama Kelas" prefWidth="155"/>
                            <TableColumn fx:id="colKelasKapasitas" text="Kapasitas" prefWidth="105"/>
                            <TableColumn fx:id="colKelasSemester" text="Semester" prefWidth="100"/>
                        </columns>
                    </TableView>
                </VBox>

                <VBox spacing="16" HBox.hgrow="ALWAYS"
                      style="-fx-background-color:white; -fx-background-radius:24; -fx-padding:24;">
                    <Label text="Manage Assignment" textFill="#0F172A">
                        <font><Font name="System Bold" size="22"/></font>
                    </Label>

                    <GridPane hgap="14" vgap="14">
                        <TextField fx:id="txtAssignmentId" promptText="Assignment ID" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <TextField fx:id="txtAssignmentNama" promptText="Nama Assignment" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                        <DatePicker fx:id="dpTanggalUnggah" promptText="Tanggal Unggah" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <DatePicker fx:id="dpDeadline" promptText="Deadline" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                        <TextField fx:id="txtAssignmentFile" promptText="File Assignment" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <TextField fx:id="txtAssignmentJamAkses" promptText="Jam Akses" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                    </GridPane>

                    <TextArea fx:id="txtAssignmentDeskripsi"
                              promptText="Deskripsi assignment..."
                              prefRowCount="3"/>

                    <HBox spacing="10">
                        <Button fx:id="btnAddAssignment" text="Add" prefWidth="105" style="-fx-background-color:#6366F1; -fx-text-fill:white; -fx-background-radius:12;"/>
                        <Button fx:id="btnEditAssignment" text="Edit" prefWidth="105" style="-fx-background-color:#F59E0B; -fx-text-fill:white; -fx-background-radius:12;"/>
                        <Button fx:id="btnDeleteAssignment" text="Delete" prefWidth="105" style="-fx-background-color:#EF4444; -fx-text-fill:white; -fx-background-radius:12;"/>
                        <Button fx:id="btnClearAssignment" text="Clear" prefWidth="105" style="-fx-background-color:#64748B; -fx-text-fill:white; -fx-background-radius:12;"/>
                    </HBox>

                    <TextField fx:id="txtSearchAssignment" promptText="Search assignment..."/>

                    <TableView fx:id="tblAssignment" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colAssignmentId" text="ID" prefWidth="70"/>
                            <TableColumn fx:id="colAssignmentNama" text="Assignment" prefWidth="190"/>
                            <TableColumn fx:id="colTanggalUnggah" text="Tanggal Upload" prefWidth="130"/>
                            <TableColumn fx:id="colDeadline" text="Deadline" prefWidth="130"/>
                            <TableColumn fx:id="colAssignmentFile" text="File" prefWidth="130"/>
                        </columns>
                    </TableView>
                </VBox>

            </HBox>
        </VBox>
    </center>
</BorderPane>