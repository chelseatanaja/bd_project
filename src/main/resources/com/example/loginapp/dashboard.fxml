<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/8.0.171"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.bd1_2.DashboardController"
            prefWidth="1280"
            prefHeight="760"
            style="-fx-background-color: linear-gradient(to bottom right, #F4F7FF, #EEF3FF);">

    <!-- SIDEBAR -->
    <left>
        <VBox prefWidth="260"
              spacing="22"
              style="-fx-background-color: linear-gradient(to bottom, #07153A, #0B0F2F);">

            <padding>
                <Insets top="32" right="18" bottom="28" left="18"/>
            </padding>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="▣"
                       textFill="#4F7CFF"
                       style="-fx-font-size:36;"/>
                <VBox spacing="2">
                    <Label text="LMS Admin" textFill="WHITE">
                        <font>
                            <Font name="System Bold" size="25"/>
                        </font>
                    </Label>
                    <Label text="Database Management" textFill="#CBD5E1">
                        <font>
                            <Font size="14"/>
                        </font>
                    </Label>
                </VBox>
            </HBox>

            <Separator opacity="0.18"/>

            <Button text="   🏠   Dashboard"
                    maxWidth="Infinity"
                    prefHeight="58"
                    style="-fx-background-color: linear-gradient(to right, #4F46E5, #2563EB);
                           -fx-text-fill:white;
                           -fx-font-size:15;
                           -fx-font-weight:bold;
                           -fx-background-radius:14;
                           -fx-alignment:CENTER_LEFT;"/>

            <Button text="   🖥   Manage Kelas"
                    maxWidth="Infinity"
                    prefHeight="48"
                    style="-fx-background-color:transparent;
                           -fx-text-fill:#E2E8F0;
                           -fx-font-size:15;
                           -fx-alignment:CENTER_LEFT;"/>

            <Button text="   📋   Manage Assignment"
                    maxWidth="Infinity"
                    prefHeight="48"
                    style="-fx-background-color:transparent;
                           -fx-text-fill:#E2E8F0;
                           -fx-font-size:15;
                           -fx-alignment:CENTER_LEFT;"/>

            <Button text="   📊   Reports"
                    maxWidth="Infinity"
                    prefHeight="48"
                    style="-fx-background-color:transparent;
                           -fx-text-fill:#E2E8F0;
                           -fx-font-size:15;
                           -fx-alignment:CENTER_LEFT;"/>

            <Region VBox.vgrow="ALWAYS"/>

            <VBox spacing="10"
                  style="-fx-background-color: rgba(255,255,255,0.08);
                         -fx-background-radius:18;
                         -fx-padding:18;">
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="◎"
                           textFill="#A5B4FC"
                           style="-fx-font-size:34;"/>
                    <VBox spacing="4">
                        <Label text="Database Status" textFill="#CBD5E1"/>
                        <Label text="PostgreSQL" textFill="#4ADE80">
                            <font>
                                <Font name="System Bold" size="15"/>
                            </font>
                        </Label>
                        <Label text="Connected" textFill="#4ADE80">
                            <font>
                                <Font name="System Bold" size="15"/>
                            </font>
                        </Label>
                    </VBox>
                </HBox>
            </VBox>

            <VBox spacing="8"
                  style="-fx-background-color: rgba(255,255,255,0.08);
                         -fx-background-radius:18;
                         -fx-padding:18;">
                <Label text="Admin User" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="15"/>
                    </font>
                </Label>
                <Label text="admin@lms.com" textFill="#CBD5E1"/>
            </VBox>

        </VBox>
    </left>

    <!-- MAIN CONTENT -->
    <center>
        <VBox spacing="24">
            <padding>
                <Insets top="34" right="36" bottom="30" left="36"/>
            </padding>

            <!-- HEADER -->
            <HBox alignment="CENTER_LEFT" spacing="18">
                <VBox spacing="6">
                    <Label text="Academic Dashboard" textFill="#0F172A">
                        <font>
                            <Font name="System Bold" size="34"/>
                        </font>
                    </Label>
                    <Label text="Manage master data, transaction data, and business reports"
                           textFill="#475569">
                        <font>
                            <Font size="15"/>
                        </font>
                    </Label>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <TextField fx:id="txtSearch"
                           promptText="Search anything..."
                           prefWidth="310"
                           prefHeight="50"
                           style="-fx-background-color:white;
                                  -fx-background-radius:16;
                                  -fx-border-color:#E2E8F0;
                                  -fx-border-radius:16;
                                  -fx-padding:0 18;
                                  -fx-font-size:14;"/>

                <Button text="⟳  Refresh"
                        prefHeight="50"
                        prefWidth="130"
                        style="-fx-background-color: linear-gradient(to right, #4F46E5, #2563EB);
                               -fx-text-fill:white;
                               -fx-font-size:15;
                               -fx-font-weight:bold;
                               -fx-background-radius:16;"/>
            </HBox>

            <!-- SUMMARY CARDS -->
            <HBox spacing="22">

                <VBox spacing="12"
                      prefWidth="280"
                      prefHeight="145"
                      style="-fx-background-color:white;
                             -fx-background-radius:22;
                             -fx-padding:22;">
                    <Label text="Total Kelas" textFill="#334155">
                        <font>
                            <Font name="System Bold" size="15"/>
                        </font>
                    </Label>

                    <Label fx:id="lblTotalKelas" text="24" textFill="#020617">
                        <font>
                            <Font name="System Bold" size="36"/>
                        </font>
                    </Label>

                    <Label text="↗  +12% this semester" textFill="#16A34A">
                        <font>
                            <Font name="System Bold" size="14"/>
                        </font>
                    </Label>
                </VBox>

                <VBox spacing="12"
                      prefWidth="280"
                      prefHeight="145"
                      style="-fx-background-color:white;
                             -fx-background-radius:22;
                             -fx-padding:22;">
                    <Label text="Assignments" textFill="#334155">
                        <font>
                            <Font name="System Bold" size="15"/>
                        </font>
                    </Label>

                    <Label fx:id="lblTotalAssignment" text="128" textFill="#020617">
                        <font>
                            <Font name="System Bold" size="36"/>
                        </font>
                    </Label>

                    <Label text="◷  18 active deadlines" textFill="#F97316">
                        <font>
                            <Font name="System Bold" size="14"/>
                        </font>
                    </Label>
                </VBox>

                <VBox spacing="12"
                      prefWidth="280"
                      prefHeight="145"
                      style="-fx-background-color:white;
                             -fx-background-radius:22;
                             -fx-padding:22;">
                    <Label text="Submissions" textFill="#334155">
                        <font>
                            <Font name="System Bold" size="15"/>
                        </font>
                    </Label>

                    <Label fx:id="lblTotalSubmission" text="842" textFill="#020617">
                        <font>
                            <Font name="System Bold" size="36"/>
                        </font>
                    </Label>

                    <Label text="●  Updated recently" textFill="#2563EB">
                        <font>
                            <Font name="System Bold" size="14"/>
                        </font>
                    </Label>
                </VBox>

            </HBox>

            <!-- CONTENT AREA -->
            <HBox spacing="24" VBox.vgrow="ALWAYS">

                <!-- MANAGE KELAS CARD -->
                <VBox spacing="16"
                      prefWidth="350"
                      style="-fx-background-color:white;
                             -fx-background-radius:24;
                             -fx-padding:24;">

                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="▣"
                               textFill="#6366F1"
                               style="-fx-font-size:26;"/>
                        <Label text="Manage Kelas" textFill="#0F172A">
                            <font>
                                <Font name="System Bold" size="22"/>
                            </font>
                        </Label>
                    </HBox>

                    <TextField fx:id="txtKelasId"
                               promptText="Kelas ID"
                               prefHeight="46"
                               style="-fx-background-color:white;
                                      -fx-border-color:#DDE6F3;
                                      -fx-border-radius:12;
                                      -fx-background-radius:12;
                                      -fx-padding:0 14;"/>

                    <TextField fx:id="txtKelasNama"
                               promptText="Nama Kelas"
                               prefHeight="46"
                               style="-fx-background-color:white;
                                      -fx-border-color:#DDE6F3;
                                      -fx-border-radius:12;
                                      -fx-background-radius:12;
                                      -fx-padding:0 14;"/>

                    <TextField fx:id="txtKelasKapasitas"
                               promptText="Kapasitas"
                               prefHeight="46"
                               style="-fx-background-color:white;
                                      -fx-border-color:#DDE6F3;
                                      -fx-border-radius:12;
                                      -fx-background-radius:12;
                                      -fx-padding:0 14;"/>

                    <TextField fx:id="txtKelasSemester"
                               promptText="Semester"
                               prefHeight="46"
                               style="-fx-background-color:white;
                                      -fx-border-color:#DDE6F3;
                                      -fx-border-radius:12;
                                      -fx-background-radius:12;
                                      -fx-padding:0 14;"/>

                    <GridPane hgap="14" vgap="14">
                        <Button fx:id="btnAddKelas"
                                text="＋  Add"
                                prefWidth="140"
                                prefHeight="52"
                                GridPane.rowIndex="0"
                                GridPane.columnIndex="0"
                                style="-fx-background-color: linear-gradient(to right, #4F46E5, #2563EB);
                                       -fx-text-fill:white;
                                       -fx-font-size:15;
                                       -fx-font-weight:bold;
                                       -fx-background-radius:13;"/>

                        <Button fx:id="btnEditKelas"
                                text="✎  Edit"
                                prefWidth="140"
                                prefHeight="52"
                                GridPane.rowIndex="0"
                                GridPane.columnIndex="1"
                                style="-fx-background-color:#2563EB;
                                       -fx-text-fill:white;
                                       -fx-font-size:15;
                                       -fx-font-weight:bold;
                                       -fx-background-radius:13;"/>

                        <Button fx:id="btnDeleteKelas"
                                text="🗑  Delete"
                                prefWidth="140"
                                prefHeight="52"
                                GridPane.rowIndex="1"
                                GridPane.columnIndex="0"
                                style="-fx-background-color:#EF4444;
                                       -fx-text-fill:white;
                                       -fx-font-size:15;
                                       -fx-font-weight:bold;
                                       -fx-background-radius:13;"/>

                        <Button fx:id="btnClearKelas"
                                text="⊗  Clear"
                                prefWidth="140"
                                prefHeight="52"
                                GridPane.rowIndex="1"
                                GridPane.columnIndex="1"
                                style="-fx-background-color:#E8ECF4;
                                       -fx-text-fill:#0F172A;
                                       -fx-font-size:15;
                                       -fx-font-weight:bold;
                                       -fx-background-radius:13;"/>
                    </GridPane>

                </VBox>

                <!-- TABLE CARD -->
                <VBox spacing="18"
                      HBox.hgrow="ALWAYS"
                      style="-fx-background-color:white;
                             -fx-background-radius:24;
                             -fx-padding:24;">

                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label text="☷"
                               textFill="#2563EB"
                               style="-fx-font-size:27;"/>

                        <Label text="Daftar Kelas" textFill="#0F172A">
                            <font>
                                <Font name="System Bold" size="22"/>
                            </font>
                        </Label>

                        <Region HBox.hgrow="ALWAYS"/>

                        <TextField fx:id="txtSearchKelas"
                                   promptText="Search kelas..."
                                   prefWidth="260"
                                   prefHeight="44"
                                   style="-fx-background-color:white;
                                          -fx-border-color:#DDE6F3;
                                          -fx-border-radius:12;
                                          -fx-background-radius:12;
                                          -fx-padding:0 14;"/>
                    </HBox>

                    <TableView fx:id="tblKelas"
                               VBox.vgrow="ALWAYS"
                               style="-fx-background-color:white;
                                      -fx-background-radius:16;
                                      -fx-border-color:#E2E8F0;
                                      -fx-border-radius:16;">

                        <columns>
                            <TableColumn fx:id="colKelasId"
                                         text="ID"
                                         prefWidth="110"/>

                            <TableColumn fx:id="colKelasNama"
                                         text="Nama Kelas"
                                         prefWidth="260"/>

                            <TableColumn fx:id="colKelasKapasitas"
                                         text="Kapasitas"
                                         prefWidth="160"/>

                            <TableColumn fx:id="colKelasSemester"
                                         text="Semester"
                                         prefWidth="210"/>
                        </columns>
                    </TableView>

                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Button text="‹"
                                prefWidth="42"
                                prefHeight="40"
                                style="-fx-background-color:#F8FAFC;
                                       -fx-border-color:#E2E8F0;
                                       -fx-border-radius:10;
                                       -fx-background-radius:10;
                                       -fx-font-size:18;"/>

                        <Button text="1"
                                prefWidth="42"
                                prefHeight="40"
                                style="-fx-background-color:#EEF2FF;
                                       -fx-text-fill:#4F46E5;
                                       -fx-font-weight:bold;
                                       -fx-background-radius:10;"/>

                        <Button text="2"
                                prefWidth="42"
                                prefHeight="40"
                                style="-fx-background-color:transparent;
                                       -fx-text-fill:#334155;"/>

                        <Button text="3"
                                prefWidth="42"
                                prefHeight="40"
                                style="-fx-background-color:transparent;
                                       -fx-text-fill:#334155;"/>

                        <Label text="..."
                               textFill="#64748B"/>

                        <Button text="10"
                                prefWidth="42"
                                prefHeight="40"
                                style="-fx-background-color:transparent;
                                       -fx-text-fill:#334155;"/>

                        <Button text="›"
                                prefWidth="42"
                                prefHeight="40"
                                style="-fx-background-color:#F8FAFC;
                                       -fx-border-color:#E2E8F0;
                                       -fx-border-radius:10;
                                       -fx-background-radius:10;
                                       -fx-font-size:18;"/>

                        <Region HBox.hgrow="ALWAYS"/>

                        <Label text="Showing 1 to 6 of 60 entries"
                               textFill="#64748B"/>
                    </HBox>

                </VBox>

            </HBox>

        </VBox>
    </center>

</BorderPane>