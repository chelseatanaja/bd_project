<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/8.0.171"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.bd1_2.SignUpController"
            prefWidth="1000"
            prefHeight="650"
            style="-fx-background-color: linear-gradient(to bottom right, #EEF2FF, #F8FAFC);">

    <left>
        <VBox alignment="CENTER"
              prefWidth="450"
              spacing="15"
              style="-fx-background-color: #111827;">

            <padding>
                <Insets top="40" bottom="40" left="40" right="40"/>
            </padding>

            <Label text="CREATE ACCOUNT" textFill="WHITE">
                <font>
                    <Font name="System Bold" size="34"/>
                </font>
            </Label>

            <Label textFill="#D1D5DB"
                   text="Start managing LMS data&#10;with PostgreSQL integration">
                <font>
                    <Font size="18"/>
                </font>
            </Label>
        </VBox>
    </left>

    <center>
        <StackPane>
            <VBox alignment="CENTER"
                  spacing="16"
                  maxWidth="380"
                  style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 35;">

                <Label text="Sign Up">
                    <font>
                        <Font name="System Bold" size="28"/>
                    </font>
                </Label>

                <TextField fx:id="txtNama"
                           promptText="Full Name"
                           prefHeight="42"/>

                <TextField fx:id="txtEmail"
                           promptText="Email"
                           prefHeight="42"/>

                <PasswordField fx:id="txtPassword"
                               promptText="Password"
                               prefHeight="42"/>

                <PasswordField fx:id="txtConfirmPassword"
                               promptText="Confirm Password"
                               prefHeight="42"/>

                <ComboBox fx:id="cmbRole"
                          promptText="Select Role"
                          prefWidth="300"
                          prefHeight="42"/>

                <Button fx:id="btnSignUp"
                        text="SIGN UP"
                        prefWidth="300"
                        prefHeight="45"
                        style="-fx-background-color:#2563EB;
                               -fx-text-fill:white;
                               -fx-font-size:15;
                               -fx-font-weight:bold;
                               -fx-background-radius:10;"/>

                <HBox alignment="CENTER" spacing="5">
                    <Label text="Already have an account?"/>
                    <Hyperlink fx:id="btnLogin"
                               text="Login"/>
                </HBox>

            </VBox>
        </StackPane>
    </center>

</BorderPane>