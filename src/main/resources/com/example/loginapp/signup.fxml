<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.loginapp.SignUpController"
            prefWidth="1000"
            prefHeight="650"
            style="-fx-background-color: linear-gradient(to bottom right, #F4F7FF, #EEF3FF);">

    <left>
        <VBox prefWidth="430"
              spacing="28"
              style="-fx-background-color: linear-gradient(to bottom, #07153A, #0B0F2F);">
            <padding>
                <Insets top="50" right="42" bottom="45" left="42"/>
            </padding>

            <Label text="Create Account" textFill="WHITE">
                <font><Font name="System Bold" size="42"/></font>
            </Label>

            <Label text="Register your account to access the LMS database management system."
                   textFill="#CBD5E1"
                   wrapText="true">
                <font><Font size="17"/></font>
            </Label>

            <Region VBox.vgrow="ALWAYS"/>

            <Label text="● PostgreSQL Ready" textFill="#4ADE80">
                <font><Font name="System Bold" size="15"/></font>
            </Label>
        </VBox>
    </left>

    <center>
        <StackPane>
            <VBox alignment="CENTER"
                  spacing="18"
                  maxWidth="410"
                  style="-fx-background-color:white;
                         -fx-background-radius:28;
                         -fx-padding:42;">

                <Label text="Sign Up" textFill="#0F172A">
                    <font><Font name="System Bold" size="34"/></font>
                </Label>

                <TextField fx:id="txtNama" promptText="Full Name" prefWidth="320" prefHeight="48"/>
                <TextField fx:id="txtEmail" promptText="Email" prefWidth="320" prefHeight="48"/>
                <PasswordField fx:id="txtPassword" promptText="Password" prefWidth="320" prefHeight="48"/>
                <PasswordField fx:id="txtConfirmPassword" promptText="Confirm Password" prefWidth="320" prefHeight="48"/>

                <ComboBox fx:id="cmbRole"
                          promptText="Select Role"
                          prefWidth="320"
                          prefHeight="48"/>

                <Button fx:id="btnSignUp"
                        text="SIGN UP"
                        prefWidth="320"
                        prefHeight="52"
                        style="-fx-background-color: linear-gradient(to right, #4F46E5, #2563EB);
                               -fx-text-fill:white;
                               -fx-font-weight:bold;
                               -fx-background-radius:15;"/>

                <HBox alignment="CENTER" spacing="5">
                    <Label text="Already have an account?"/>
                    <Hyperlink fx:id="btnLogin" text="Login"/>
                </HBox>

            </VBox>
        </StackPane>
    </center>

</BorderPane>