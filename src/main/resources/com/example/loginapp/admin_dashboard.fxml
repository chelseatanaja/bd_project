<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.loginapp.AdminDashboardController"
            prefWidth="1280"
            prefHeight="760"
            style="-fx-background-color: linear-gradient(to bottom right, #F4F7FF, #EEF3FF);">

    <left>
        <VBox prefWidth="260" spacing="20"
              style="-fx-background-color: linear-gradient(to bottom, #07153A, #0B0F2F);">
            <padding>
                <Insets top="32" right="18" bottom="28" left="18"/>
            </padding>

            <Label text="LMS Admin" textFill="WHITE">
                <font><Font name="System Bold" size="28"/></font>
            </Label>

            <Label text="Database Management" textFill="#CBD5E1"/>

            <Separator opacity="0.18"/>

            <Button fx:id="btnDashboard" text="   🏠 Dashboard" maxWidth="Infinity" prefHeight="50"/>
            <Button fx:id="btnKelas" text="   🖥 Manage Kelas" maxWidth="Infinity" prefHeight="50"/>
            <Button fx:id="btnAssignment" text="   📋 Manage Assignment" maxWidth="Infinity" prefHeight="50"/>
            <Button fx:id="btnLogout" text="   🚪 Logout" maxWidth="Infinity" prefHeight="50"/>

            <Region VBox.vgrow="ALWAYS"/>

            <VBox spacing="8"
                  style="-fx-background-color:rgba(255,255,255,0.08);
                         -fx-background-radius:18;
                         -fx-padding:18;">
                <Label text="Database Status" textFill="#CBD5E1"/>
                <Label text="● PostgreSQL Connected" textFill="#4ADE80"/>
            </VBox>
        </VBox>
    </left>

    <center>
        <VBox spacing="24">
            <padding>
                <Insets top="34" right="36" bottom="30" left="36"/>
            </padding>

            <HBox alignment="CENTER_LEFT">
                <VBox>
                    <Label text="Admin Dashboard" textFill="#0F172A">
                        <font><Font name="System Bold" size="34"/></font>
                    </Label>
                    <Label text="Overview of LMS database activity" textFill="#64748B"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <Button fx:id="btnRefresh"
                        text="Refresh"
                        prefWidth="130"
                        prefHeight="48"
                        style="-fx-background-color:#2563EB;
                               -fx-text-fill:white;
                               -fx-font-weight:bold;
                               -fx-background-radius:14;"/>
            </HBox>

            <HBox spacing="22">
                <VBox prefWidth="260" spacing="12" style="-fx-background-color:white; -fx-background-radius:22; -fx-padding:22;">
                    <Label text="Total Kelas" textFill="#64748B"/>
                    <Label fx:id="lblTotalKelas" text="24" textFill="#0F172A">
                        <font><Font name="System Bold" size="36"/></font>
                    </Label>
                </VBox>

                <VBox prefWidth="260" spacing="12" style="-fx-background-color:white; -fx-background-radius:22; -fx-padding:22;">
                    <Label text="Assignments" textFill="#64748B"/>
                    <Label fx:id="lblTotalAssignment" text="128" textFill="#0F172A">
                        <font><Font name="System Bold" size="36"/></font>
                    </Label>
                </VBox>

                <VBox prefWidth="260" spacing="12" style="-fx-background-color:white; -fx-background-radius:22; -fx-padding:22;">
                    <Label text="Users" textFill="#64748B"/>
                    <Label fx:id="lblTotalUser" text="36" textFill="#0F172A">
                        <font><Font name="System Bold" size="36"/></font>
                    </Label>
                </VBox>
            </HBox>

            <VBox spacing="18"
                  VBox.vgrow="ALWAYS"
                  style="-fx-background-color:white;
                         -fx-background-radius:24;
                         -fx-padding:24;">

                <Label text="Recent Data" textFill="#0F172A">
                    <font><Font name="System Bold" size="24"/></font>
                </Label>

                <TableView fx:id="tblRecent" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colRecentId" text="ID" prefWidth="120"/>
                        <TableColumn fx:id="colRecentType" text="Type" prefWidth="200"/>
                        <TableColumn fx:id="colRecentName" text="Name" prefWidth="320"/>
                        <TableColumn fx:id="colRecentStatus" text="Status" prefWidth="200"/>
                    </columns>
                </TableView>

            </VBox>
        </VBox>
    </center>

</BorderPane>